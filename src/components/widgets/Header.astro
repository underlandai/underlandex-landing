---
import Logo from '~/components/Logo.astro';
import ToggleMenu from '~/components/common/ToggleMenu.astro';

import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
}

interface ActionLink extends Link {
  variant?: string;
  openRequestAccess?: boolean;
}

export interface Props {
  id?: string;
  links?: Array<Link>;
  actions?: Array<ActionLink>;
  isSticky?: boolean;
  isFullWidth?: boolean;
  position?: string;
}

const {
  id = 'header',
  links = [],
  actions = [],
  isSticky = false,
  isFullWidth = false,
} = Astro.props;
---

<header
  class:list={[
    { sticky: isSticky, relative: !isSticky },
    'top-0 z-40 flex-none mx-auto w-full border-b border-gray-100 bg-white/95 backdrop-blur-md transition-[opacity] ease-in-out',
  ]}
  {...isSticky ? { 'data-aw-sticky-header': true } : {}}
  {...id ? { id } : {}}
>
  <div
    class:list={[
      'relative text-default py-3 px-4 md:px-6 mx-auto w-full md:flex md:justify-between md:items-center',
      { 'max-w-7xl': !isFullWidth },
    ]}
  >
    <div class="flex justify-between items-center">
      <a class="flex items-center" href={getHomePermalink()} aria-label="UnderlandEX home">
        <Logo withTagline={true} />
      </a>
      <div class="flex items-center md:hidden">
        <ToggleMenu />
      </div>
    </div>
    <nav
      class="items-center w-full md:w-auto hidden md:flex md:mx-5 text-default overflow-y-auto overflow-x-hidden md:overflow-visible md:justify-self-center"
      aria-label="Main navigation"
    >
      <ul class="flex flex-col md:flex-row md:self-center w-full md:w-auto text-sm tracking-tight">
        {
          links.map(({ text, href, ariaLabel }) => (
            <li>
              <a
                class="hover:text-primary px-3 py-3 flex items-center font-medium transition"
                href={href}
                aria-label={ariaLabel}
              >
                {text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="hidden md:flex items-center gap-2">
      {
        actions.map(({ variant, text, href, openRequestAccess }) => {
          const baseCls =
            variant === 'primary'
              ? 'bg-primary hover:bg-primary/90 text-white'
              : 'text-default hover:text-primary';
          const cls = `inline-flex items-center font-medium text-sm px-4 py-2 rounded-md transition ${baseCls}`;
          if (openRequestAccess) {
            return (
              <button type="button" data-open-request-access class={cls}>
                {text}
              </button>
            );
          }
          return (
            <a href={href} class={cls}>
              {text}
            </a>
          );
        })
      }
    </div>
  </div>
</header>
