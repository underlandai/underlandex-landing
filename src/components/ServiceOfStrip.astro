---
import Image from '~/components/common/Image.astro';
import lichenWordmark from '~/assets/images/lichen/wordmark-black.svg';
---

<div class="w-full bg-[#fafaf7] border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2 flex items-center justify-end gap-3 text-xs text-gray-600">
    <span class="tracking-wide">A service of</span>
    <a
      href="https://lichen.com.au"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center hover:opacity-80 transition-opacity"
      aria-label="Lichen Commodities"
    >
      <Image
        src={lichenWordmark}
        alt="Lichen Commodities"
        width={140}
        height={24}
        class="h-5 w-auto"
      />
    </a>
  </div>
</div>
