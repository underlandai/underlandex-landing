---
import { SITE, METADATA, APP_BLOG } from 'astrowind:config';
import Layout from '~/layouts/PageLayout.astro';
import ServiceOfStrip from '~/components/ServiceOfStrip.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import RequestAccessModal from '~/components/RequestAccessModal.astro';
import Grid from '~/components/blog/Grid.astro';
import Pagination from '~/components/blog/Pagination.astro';

import { blogListRobots, fetchPosts } from '~/utils/blog';
import { headerData, footerData } from '~/navigation';

export const prerender = true;

const posts = await fetchPosts();

const metadata = {
  title: `Insights — UnderlandEX`,
  robots: {
    index: blogListRobots?.index,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement">
    <ServiceOfStrip />
    <Header {...headerData} isSticky />
  </Fragment>

  <section class="px-4 md:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-6xl">
    <header class="mb-8 md:mx-auto md:mb-12 text-center">
      <p class="text-base font-semibold uppercase tracking-wide text-primary mb-2">The UnderlandEX Insights</p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight tracking-tighter mb-4 font-heading">
        Weekly market intelligence
      </h1>
      <p class="max-w-3xl mx-auto text-xl text-muted">
        New data drops, deal commentary and research from the UnderlandEX team.
      </p>
    </header>

    <Grid posts={posts} />
  </section>

  <Footer {...footerData} />
  <RequestAccessModal />
</Layout>
