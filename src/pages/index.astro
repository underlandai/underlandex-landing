---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import ProductPreview from '~/components/ProductPreview.astro';
import MnaTeaser from '~/components/MnaTeaser.astro';
import RequestAccessModal from '~/components/RequestAccessModal.astro';

import { headerData, footerData } from '~/navigation';

import heroGeo from '~/assets/images/underlandex/hero-geo.avif';
import previewExplorer from '~/assets/images/underlandex/preview-explorer.png';
import previewMna from '~/assets/images/underlandex/preview-mna.png';

const metadata = {
  title: 'UnderlandEX — The world-leading mining intelligence platform',
  ignoreTitleTemplate: true,
};

// Build-time fetch from prod stats API (rebuilds on deploy)
let liveStats = {
  totalSites: 255344,
  totalOwners: 3449,
  totalTenements: 85537,
  totalProjects: 5968,
  totalResourceEstimates: 70515,
};
try {
  const res = await fetch('https://app.underlandex.com/api/stats', { signal: AbortSignal.timeout(5000) });
  if (res.ok) {
    const data = await res.json();
    liveStats = { ...liveStats, ...data };
  }
} catch (e) {
  // fall back to hardcoded defaults above
}

const fmt = (n: number) => n.toLocaleString('en-AU');
---

<Layout metadata={metadata}>
  <Fragment slot="announcement">
    <Header {...headerData} isSticky />
  </Fragment>

  <!-- HERO -->
  <Hero
    tagline="The world-leading mining intelligence platform"
    actions={[
      { variant: 'primary', text: 'Request Access', href: '#request-access' },
      { variant: 'secondary', text: 'Enquire', href: 'mailto:oliver@underlandex.com' },
    ]}
    image={{ src: heroGeo, alt: 'Subsurface geological model' }}
  >
    <Fragment slot="title">
      The world beneath,<br />
      <span class="text-primary">mapped.</span>
    </Fragment>
    <Fragment slot="subtitle">
      Explore <strong>{fmt(liveStats.totalSites)}+</strong> mining assets, track every deal, and be first to know.
      Always live. Continuously updated.
    </Fragment>
    <Fragment slot="content">
      <div class="flex justify-center mt-8">
        <a href="#data" class="text-muted hover:text-primary transition animate-bounce" aria-label="Scroll to data">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </div>
    </Fragment>
  </Hero>

  <!-- LIVE STATS TICKER -->
  <Stats
    id="data"
    tagline="The database, in numbers"
    title="Live from the world's most comprehensive mining dataset"
    subtitle="Always live. Continuously updated from the world's major stock exchanges and regulatory registries."
    stats={[
      { amount: `${fmt(liveStats.totalSites)}+`, title: 'Mining assets tracked', icon: 'tabler:map-pin' },
      { amount: `${fmt(liveStats.totalOwners)}+`, title: 'Mining companies', icon: 'tabler:building-factory-2' },
      { amount: `${fmt(liveStats.totalTenements)}+`, title: 'Tenements mapped', icon: 'tabler:file-certificate' },
      { amount: `${fmt(liveStats.totalResourceEstimates)}+`, title: 'JORC resource estimates', icon: 'tabler:chart-bar' },
    ]}
  />

  <!-- CAPABILITY CARDS -->
  <Features3
    id="products"
    tagline="Three products. One platform."
    title="Built for the way the mining market actually works."
    columns={3}
    defaultIcon="tabler:arrow-right"
    items={[
      {
        title: 'UnderlandEX Explorer',
        description:
          'Discover. Search thousands of live projects across every commodity, jurisdiction, stage and ownership. Familiar search patterns built for how property investors think.',
        icon: 'tabler:search',
      },
      {
        title: 'UnderlandEX M&A',
        description:
          'Be first to know. Real-time deal radar ingesting every listed-company announcement from the ASX, TSX, LSE and EDGAR. Morning brief, weekly report, league tables.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Portal3D',
        description:
          'See beneath the surface. Browser-based 3D visualisation of subsurface geology. Bring mining assets to life for buyers, partners and investors.',
        icon: 'tabler:3d-cube-sphere',
      },
    ]}
  />

  <!-- GATED PREVIEW: EXPLORER -->
  <ProductPreview
    badge="UnderlandEX Explorer"
    title="Every deposit. Every tenement. Every owner."
    caption="Search the database the way property investors search homes. Filter by commodity, jurisdiction, stage and ownership. Open any asset to see the full technical picture — resource estimates, production history, partnership structure."
    image={previewExplorer}
  />

  <!-- GATED PREVIEW: M&A -->
  <ProductPreview
    badge="UnderlandEX M&A"
    title="Be first to every deal."
    caption="A live feed of every listed-company announcement that moves the market. M&A, capital raises, resource upgrades, exploration results — pulled from stock exchange disclosures the moment they hit the wire, enriched with UnderlandEX project context."
    image={previewMna}
    reverse={true}
  />

  <!-- LIVE WIRE: recent M&A deals from mna.underlandex.com -->
  <MnaTeaser />

  <!-- WHO IT'S FOR -->
  <Features3
    tagline="Who it's for"
    title="Tailored to the people who move the market."
    columns={3}
    defaultIcon="tabler:users"
    items={[
      { title: 'Institutional investors', description: 'Screen 255,000+ assets, model comparable transactions, monitor portfolio-wide exposure.', icon: 'tabler:briefcase' },
      { title: 'Exploration companies', description: 'Benchmark projects against peers. Identify tenement adjacencies. Find partners.', icon: 'tabler:drone' },
      { title: 'Commodity traders', description: 'Live price feeds, production tracking, and deal flow across all listed materials names.', icon: 'tabler:chart-candle' },
      { title: 'Royalty holders', description: 'Valuation comparables for every JORC-estimated deposit. NAV modelling and stream analysis.', icon: 'tabler:coin' },
      { title: 'Governments & regulators', description: 'Jurisdiction-wide tenement maps, ownership chains and production histories, all in one place.', icon: 'tabler:gavel' },
      { title: 'Family offices', description: 'Access to the resources sector once reserved for institutional desks. Simple, comprehensive, private.', icon: 'tabler:building-bank' },
    ]}
  />

  <!-- DATA DEPTH -->
  <Content
    id="about"
    tagline="Beyond the surface"
    title="Most platforms show what's listed. We show what's there."
    items={[
      {
        title: 'Every listed mining asset',
        description:
          'Continuously ingested from stock exchange announcements, regulatory filings and jurisdictional registries across Australia, Canada, the UK and the USA.',
        icon: 'tabler:database',
      },
      {
        title: 'Every deal, as it happens',
        description:
          'ASX, TSX, LSE and EDGAR announcement feeds. M&A, capital raises, JORC updates, exploration results — in one place.',
        icon: 'tabler:rss',
      },
      {
        title: 'Every tenement boundary',
        description:
          'Spatial data across Australian jurisdictions, with expansion into Canada, the USA and Africa underway.',
        icon: 'tabler:map',
      },
    ]}
    image={{ src: heroGeo, alt: 'Subsurface geological model' }}
  >
    <Fragment slot="content">
      <p class="text-muted">
        UnderlandEX is the world-leading mining intelligence database. Our backend continuously ingests every listed
        mining company announcement across the world's major stock exchanges — surfacing the deposits, deals and data
        points that no other platform has assembled in one place.
      </p>
    </Fragment>
  </Content>

  <!-- PRICING -->
  <Pricing
    id="pricing"
    tagline="Access"
    title="Simple tiers. Scaled to the way you work."
    prices={[
      {
        title: 'Explorer',
        subtitle: 'Discover and evaluate',
        price: 'Free',
        period: 'Invitation on approval',
        items: [
          { description: 'Search listed projects' },
          { description: 'Basic commodity & jurisdiction filters' },
          { description: 'Public ownership data' },
        ],
        callToAction: { text: 'Request access', href: '#request-access' },
      },
      {
        title: 'Professional',
        subtitle: 'Full Explorer + M&A',
        price: 'Contact',
        period: 'per seat / month',
        items: [
          { description: 'Everything in Explorer' },
          { description: 'Real-time M&A deal radar' },
          { description: 'Morning brief + weekly report' },
          { description: 'JORC resource estimates & production history' },
          { description: 'CSV export' },
        ],
        callToAction: { text: 'Request pricing', href: '#request-access' },
        hasRibbon: true,
        ribbonTitle: 'Most popular',
      },
      {
        title: 'Enterprise',
        subtitle: 'Full platform + API',
        price: 'Bespoke',
        period: 'Annual contract',
        items: [
          { description: 'Everything in Professional' },
          { description: 'Portal3D seats' },
          { description: 'API access & bulk data export' },
          { description: 'Priority support' },
          { description: 'Dedicated account manager' },
        ],
        callToAction: { text: 'Enquire', href: 'mailto:oliver@underlandex.com' },
      },
    ]}
  />

  <!-- INSIGHTS / BLOG -->
  <BlogLatestPosts
    id="insights"
    title="Insights"
    information={'Weekly intelligence briefings, data drops and market commentary.'}
  />

  <!-- FINAL CTA -->
  <CallToAction
    id="request-access-cta"
    actions={[
      { variant: 'primary', text: 'Request Access', href: '#request-access' },
    ]}
  >
    <Fragment slot="title">See every deposit. Track every deal.</Fragment>
    <Fragment slot="subtitle">
      Join the institutional investors, traders and exploration teams already using UnderlandEX.
    </Fragment>
  </CallToAction>

  <Footer {...footerData} />

  <!-- GLOBAL MODAL -->
  <RequestAccessModal />
</Layout>
