---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = { title: 'Privacy Policy — UnderlandEX' };
---

<Layout metadata={metadata}>
  <Fragment slot="announcement">
    <Header {...headerData} isSticky />
  </Fragment>

  <section class="py-16 px-4 max-w-3xl mx-auto">
    <h1 class="font-heading font-bold text-4xl mb-4">Privacy Policy</h1>
    <p class="text-muted mb-8">Last updated: April 2026</p>

    <div class="prose prose-slate max-w-none space-y-6 text-base leading-relaxed">
      <p>UnderlandEX is operated by Lichen Commodities Pty Ltd (ACN pending), a company incorporated in Australia. We are committed to protecting your personal information in accordance with the <em>Privacy Act 1988</em> (Cth) and the Australian Privacy Principles.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Information we collect</h2>
      <p>We collect information you provide directly — name, work email, company and role — when you request access or contact us. We also collect standard server logs (IP address, browser type, pages visited) and, where enabled, analytics events via PostHog.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">How we use it</h2>
      <p>We use your information to evaluate access requests, communicate with you about your account, and improve the platform. We do not sell personal information to third parties.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Third-party services</h2>
      <p>We use Resend for transactional email, Auth0 for authentication, and Airtable for CRM. Each service operates under its own privacy policy. Data is stored in Australia or the United States.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Your rights</h2>
      <p>You may request access to, correction of, or deletion of your personal information at any time by emailing <a href="mailto:oliver@underlandex.com" class="text-primary underline">oliver@underlandex.com</a>.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Contact</h2>
      <p>For privacy enquiries: <a href="mailto:oliver@underlandex.com" class="text-primary underline">oliver@underlandex.com</a></p>
    </div>
  </section>

  <Footer {...footerData} />
</Layout>
