---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import { headerData, footerData } from '~/navigation';

const metadata = { title: 'Terms of Service — UnderlandEX' };
---

<Layout metadata={metadata}>
  <Fragment slot="announcement">
    <Header {...headerData} isSticky />
  </Fragment>

  <section class="py-16 px-4 max-w-3xl mx-auto">
    <h1 class="font-heading font-bold text-4xl mb-4">Terms of Service</h1>
    <p class="text-muted mb-8">Last updated: April 2026</p>

    <div class="prose prose-slate max-w-none space-y-6 text-base leading-relaxed">
      <p>These Terms of Service govern your access to and use of the UnderlandEX platform, operated by Lichen Commodities Pty Ltd ("we", "us"). By accessing the platform you agree to these terms.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Access</h2>
      <p>Access to UnderlandEX is by invitation only. We may revoke access at our discretion. You must not share your credentials or permit unauthorised access to the platform.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Permitted use</h2>
      <p>The platform and its data are provided for internal research and evaluation purposes only. You must not redistribute, resell, scrape, or reproduce platform data without our written consent.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">No financial advice</h2>
      <p>Information on UnderlandEX is for informational purposes only and does not constitute financial, investment, legal or tax advice. Always seek independent professional advice before making investment decisions.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Accuracy</h2>
      <p>We endeavour to keep data accurate and current but make no warranty as to completeness, accuracy or fitness for purpose. Data is sourced from public exchange disclosures and regulatory registries.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Limitation of liability</h2>
      <p>To the maximum extent permitted by law, Lichen Commodities Pty Ltd is not liable for any loss or damage arising from your use of or reliance on the platform.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Governing law</h2>
      <p>These terms are governed by the laws of Western Australia, Australia. Any disputes will be subject to the exclusive jurisdiction of the courts of Western Australia.</p>

      <h2 class="font-heading font-semibold text-xl mt-8 mb-2">Contact</h2>
      <p>Questions: <a href="mailto:oliver@underlandex.com" class="text-primary underline">oliver@underlandex.com</a></p>
    </div>
  </section>

  <Footer {...footerData} />
</Layout>
